<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap 5 Layout - No Nav</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="d-flex flex-column vh-100 bg-light">

    <header class="bg-dark text-white py-4 shadow-sm">
        <div class="container text-center">
            <h1 class="display-6 fw-bold m-0">AB Company </h1>
        </div>
    </header>

    <main class="flex-shrink-0 container my-auto py-5">
        
        <div class="row g-4 align-items-start">
            
            <div class="col-lg-8">
                <div class="p-4 p-md-5 bg-white rounded-3 border shadow-sm">
                    <h2 class="fw-bold border-bottom pb-2">Main Content</h2>
                    <p class="lead mt-3 text-secondary">
                       simplified layout using Bootstrap grid.
                    </p>
                    <p>The layout is fully responsive; the sidebar will move below this section on smaller screens.</p>
                </div>
            </div>
            
            <aside class="col-lg-4">
                <div class="p-4 bg-white border rounded-3 shadow-sm">
                    <h3 class="h5 fw-bold mb-3 text-primary">Side bar</h3>
        
                </div>
            </aside>

        </div>
    </main>

    <footer class="mt-auto py-3 bg-dark text-white text-center">
        <div class="container">
            <small>&copy; 2026 AB Company . All rights reserved.</small>
        </div>
    </footer>

</body>
</html>